# ============================================
# Production Dockerfile
# Uses pre-built frontend from ./public directory
# The frontend is built by GitHub Actions CI, not during Docker build
# ============================================
FROM node:18-alpine

WORKDIR /app

# Copy backend package files and install production deps
COPY package*.json ./
RUN npm ci --omit=dev

# Copy backend source code (includes pre-built frontend in ./public)
COPY . .

EXPOSE 5500

CMD ["node", "index.js"]
