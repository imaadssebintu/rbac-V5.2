# Clerk Authentication
# Get your publishable key from https://dashboard.clerk.com
REACT_APP_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY

# API URL (defaults to http://localhost:5500/api for local dev)
REACT_APP_API_URL=/api

# Set to 'true' if you want local frontend to hit a remote API
REACT_APP_USE_REMOTE_API_IN_LOCAL=false

# Override the local API URL (defaults to http://localhost:5500/api)
# REACT_APP_LOCAL_API_URL=http://localhost:5500/api
